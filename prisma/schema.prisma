generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin User ──────────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Destinations ────────────────────────────────────────────────
model Destination {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  region      String
  description String
  image       String
  highlights  String // JSON array stored as string
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  priceFrom   Int      @default(0)
  active        Boolean  @default(true)
  isTemplate    Boolean  @default(true)
  publishStatus String   @default("approved")
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotels                   DestinationHotel[]
  packages                 DestinationPackage[]
  excursions               DestinationExcursion[]
  transportServices        DestinationTransportService[]
  cruises                  DestinationCruise[]
  hotelPrimaryRefs         Hotel[]                       @relation("HotelPrimaryDestination")
  packagePrimaryRefs       TravelPackage[]               @relation("PackagePrimaryDestination")
  excursionPrimaryRefs     Excursion[]                   @relation("ExcursionPrimaryDestination")
  transportOriginRefs      TransportService[]            @relation("TransportOriginDestination")
  transportDestinationRefs TransportService[]            @relation("TransportTargetDestination")
  cruisePrimaryRefs        Cruise[]                      @relation("CruisePrimaryDestination")

  resellerId String?
  reseller   Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([active, isTemplate])
  @@index([order])
  @@index([resellerId])
}

// ─── Hotels ──────────────────────────────────────────────────────
model Hotel {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  cityId        String
  cityName      String
  stars         Int      @default(3)
  address       String   @default("")
  description   String   @default("")
  images        String   @default("[]") // JSON array
  amenities     String   @default("[]") // JSON array of amenity IDs
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  priceFrom     Int      @default(0)
  tags          String   @default("[]") // JSON array
  featured      Boolean  @default(false)
  active        Boolean  @default(true)
  isTemplate    Boolean  @default(true)
  publishStatus String   @default("approved")
  destinationId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roomTypes     RoomType[]
  allotments    Allotment[]
  destination   Destination?       @relation("HotelPrimaryDestination", fields: [destinationId], references: [id], onDelete: SetNull)
  destinations  DestinationHotel[]
  packageHotels PackageHotel[]
  resellerId    String?
  reseller      Reseller?          @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([destinationId])
  @@index([active, isTemplate])
  @@index([featured, active])
  @@index([resellerId])
}

// ─── Room Types ──────────────────────────────────────────────────
model RoomType {
  id            String   @id @default(cuid())
  hotelId       String
  name          String
  maxGuests     Int      @default(2)
  beds          String   @default("1 cama doble")
  basePrice     Int      @default(0)
  originalPrice Int      @default(0)
  includes      String   @default("[]") // JSON array
  roomImage     String   @default("")
  roomImages    String   @default("[]") // JSON array
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel            Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  allotments       Allotment[]
  packageRoomTypes PackageRoomType[]

  @@index([hotelId, active])
}

// ─── Allotments ──────────────────────────────────────────────────
model Allotment {
  id          String   @id @default(cuid())
  hotelId     String
  roomTypeId  String
  dateFrom    DateTime
  dateTo      DateTime
  totalRooms  Int      @default(0)
  bookedRooms Int      @default(0)
  releaseDays Int      @default(3)
  netPrice    Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel    Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
}

// ─── Marketing Modal ─────────────────────────────────────────────
model MarketingModal {
  id           String    @id @default(cuid())
  active       Boolean   @default(true)
  title        String    @default("")
  subtitle     String    @default("")
  description  String    @default("")
  imageUrl     String    @default("")
  ctaText      String    @default("Ver Oferta")
  ctaLink      String    @default("")
  ctaType      String    @default("link") // "link" | "navigate" — link opens URL, navigate uses SPA view
  timerEnabled Boolean   @default(false)
  timerLabel   String    @default("Oferta termina en")
  timerEnd     DateTime?
  position     String    @default("center") // "center" | "bottom-right" | "bottom-left"
  delayMs      Int       @default(3000) // delay before showing modal (ms)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Travel Packages ─────────────────────────────────────────────
model TravelPackage {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  destinationId        String
  destinationName      String
  title                String
  description          String
  duration             String
  price                Int
  originalPrice        Int?
  includes             String   @default("[]") // JSON array
  image                String   @default("")
  difficulty           String   @default("Fácil")
  groupSize            String   @default("")
  departureDates       String   @default("[]") // JSON array
  rating               Float    @default(0)
  soldOut              Boolean  @default(false)
  category             String   @default("Cultural")
  commission           Int      @default(10)
  active               Boolean  @default(true)
  isTemplate           Boolean  @default(true)
  publishStatus        String   @default("approved")
  primaryDestinationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  primaryDestination Destination?              @relation("PackagePrimaryDestination", fields: [primaryDestinationId], references: [id], onDelete: SetNull)
  destinations       DestinationPackage[]
  hotels             PackageHotel[]
  excursions         PackageExcursion[]
  transportServices  PackageTransportService[]
  roomTypes          PackageRoomType[]
  departureDatesRel  PackageDepartureDate[]
  itineraryDays      PackageItineraryDay[]
  includedServices   PackageIncludedService[]
  resellerId         String?
  reseller           Reseller?                 @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([primaryDestinationId])
  @@index([destinationId])
  @@index([active, isTemplate])
  @@index([category, active])
  @@index([resellerId])
}

// ─── Excursions ───────────────────────────────────────────────────
model Excursion {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  destinationId    String
  destinationName  String
  cityName         String
  description      String
  shortDesc        String   @default("")
  images           String   @default("[]") // JSON array
  duration         String   @default("")
  difficulty       String   @default("Fácil")
  groupSize        String   @default("")
  basePrice        Int      @default(0)
  childPrice       Int      @default(0)
  includes         String   @default("[]") // JSON array
  excludes         String   @default("[]") // JSON array
  requirements     String   @default("[]") // JSON array
  category         String   @default("")
  rating           Float    @default(0)
  featured         Boolean  @default(false)
  active           Boolean  @default(true)
  isTemplate       Boolean  @default(true)
  publishStatus    String   @default("approved")
  destinationRefId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  destinationRef    Destination?           @relation("ExcursionPrimaryDestination", fields: [destinationRefId], references: [id], onDelete: SetNull)
  destinations      DestinationExcursion[]
  packageExcursions PackageExcursion[]
  resellerId        String?
  reseller          Reseller?              @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([destinationRefId])
  @@index([destinationId])
  @@index([active, isTemplate])
  @@index([category, active])
  @@index([featured, active])
  @@index([resellerId])
}

// ─── Subagents ────────────────────────────────────────────────────
model Subagent {
  id                String   @id @default(cuid())
  code              String   @unique
  email             String   @unique
  password          String
  agencyName        String   @default("")
  contactName       String   @default("")
  country           String   @default("")
  phone             String   @default("")
  commission        Int      @default(0)
  sellerLevel       String   @default("standard")
  type              String   @default("subagent") // "reseller" | "subagent"
  whiteLabelEnabled Boolean  @default(false)
  active            Boolean  @default(false)
  approvalStatus    String   @default("pending")
  registrationDate  DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bookings Booking[]
}

// ─── Resellers ────────────────────────────────────────────────────
model Reseller {
  id                String    @id @default(cuid())
  code              String    @unique
  email             String    @unique
  password          String
  companyName       String    @default("")
  contactName       String    @default("")
  country           String    @default("")
  phone             String    @default("")
  website           String    @default("")
  taxId             String    @default("")
  address           String    @default("")
  logoUrl           String    @default("")
  sellerLevel       String    @default("standard")
  commission        Int       @default(0)
  whiteLabelEnabled Boolean   @default(false)
  active            Boolean   @default(false)
  approvalStatus    String    @default("pending")
  rejectionReason   String    @default("")
  registrationDate  DateTime  @default(now())
  approvedAt        DateTime?
  approvedBy        String?
  lastLoginAt       DateTime?
  customDomain      String?   @unique
  subdomain         String?   @unique
  whiteLabelConfig  String    @default("{}") // JSON: storeName, slogan, colors, etc.
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bookings          Booking[]
  catalogs          ResellerCatalog[]
  sales             ResellerSale[]
  clients           ResellerClient[]
  documents         ResellerDocument[]
  hotels            Hotel[]
  excursions        Excursion[]
  packages          TravelPackage[]
  transportServices TransportService[]
  cruises           Cruise[]
  destinations      Destination[]

  @@index([active, approvalStatus])
  @@index([sellerLevel])
  @@index([customDomain])
  @@index([subdomain])
}

model ResellerCatalog {
  id                String   @id @default(cuid())
  resellerId        String
  sourceType        String
  sourceId          String
  customPrice       Int?
  customName        String   @default("")
  customDescription String   @default("")
  active            Boolean  @default(true)
  featured          Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@unique([resellerId, sourceType, sourceId])
  @@index([resellerId, sourceType])
  @@index([resellerId, active])
  @@index([sourceType, sourceId])
}

model ResellerSale {
  id            String   @id @default(cuid())
  resellerId    String
  bookingId     String?
  clientName    String   @default("")
  clientEmail   String   @default("")
  totalAmount   Int      @default(0)
  commissionAmt Int      @default(0)
  netAmount     Int      @default(0)
  status        String   @default("pending")
  saleDate      DateTime @default(now())
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reseller Reseller @relation(fields: [resellerId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([resellerId, status])
  @@index([resellerId, saleDate])
  @@index([bookingId])
}

model ResellerClient {
  id             String   @id @default(cuid())
  resellerId     String
  name           String
  email          String
  phone          String   @default("")
  country        String   @default("")
  passport       String   @default("")
  notes          String   @default("")
  totalPurchases Int      @default(0)
  totalSpent     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId, email])
  @@index([resellerId, name])
}

model ResellerDocument {
  id            String    @id @default(cuid())
  resellerId    String
  docType       String
  fileName      String
  fileUrl       String
  status        String    @default("pending")
  reviewerNotes String    @default("")
  uploadedAt    DateTime  @default(now())
  reviewedAt    DateTime?

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId, status])
}

// ─── Bookings ─────────────────────────────────────────────────────
model Booking {
  id            String    @id @default(cuid())
  code          String    @unique
  guestName     String    @default("")
  guestEmail    String    @default("")
  guestPhone    String    @default("")
  guestCountry  String    @default("")
  adults        Int       @default(1)
  children      Int       @default(0)
  childrenAges  String    @default("[]") // JSON array
  notes         String    @default("")
  status        String    @default("pending")
  totalPrice            Int       @default(0)
  netPrice              Int       @default(0)
  commissionAmt         Int       @default(0)
  subagentCommissionAmt Int       @default(0)
  checkIn       DateTime?
  checkOut      DateTime?
  bookedBy      String    @default("b2c") // "b2c" | "b2b"
  subagentId    String?
  resellerId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         BookingItem[]
  subagent      Subagent?      @relation(fields: [subagentId], references: [id], onDelete: SetNull)
  reseller      Reseller?      @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  resellerSales ResellerSale[]

  @@index([resellerId])
  @@index([subagentId])
}

// ─── Booking Items ────────────────────────────────────────────────
model BookingItem {
  id          String   @id @default(cuid())
  bookingId   String
  itemType    String   @default("") // "hotel", "excursion", "transport", etc.
  serviceId   String   @default("")
  serviceName String   @default("")
  roomTypeId  String   @default("")
  roomName    String   @default("")
  dateFrom    String   @default("")
  dateTo      String   @default("")
  quantity    Int      @default(1)
  unitPrice   Int      @default(0)
  totalPrice  Int      @default(0)
  addons      String   @default("[]") // JSON array
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ─── Transport Providers ───────────────────────────────────────────
model TransportProvider {
  id          String   @id @default(cuid())
  name        String
  legalName   String   @default("")
  nit         String   @default("")
  phone       String   @default("")
  email       String   @default("")
  vehicleType String   @default("")
  capacity    Int      @default(0)
  active      Boolean  @default(true)
  isTemplate  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services TransportService[]
}

// ─── Transport Services ────────────────────────────────────────────
model TransportService {
  id                       String   @id @default(cuid())
  providerId               String
  name                     String
  routeType                String   @default("")
  origin                   String   @default("")
  destination              String   @default("")
  cityId                   String   @default("")
  cityName                 String   @default("")
  durationMins             Int      @default(0)
  basePrice                Int      @default(0)
  pricePerExtra            Int      @default(0)
  includes                 String   @default("[]") // JSON array
  notes                    String   @default("")
  active                   Boolean  @default(true)
  isTemplate               Boolean  @default(true)
  publishStatus            String   @default("approved")
  originDestinationId      String?
  destinationDestinationId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  provider                  TransportProvider             @relation(fields: [providerId], references: [id], onDelete: Cascade)
  originDestinationRef      Destination?                  @relation("TransportOriginDestination", fields: [originDestinationId], references: [id], onDelete: SetNull)
  destinationDestinationRef Destination?                  @relation("TransportTargetDestination", fields: [destinationDestinationId], references: [id], onDelete: SetNull)
  destinations              DestinationTransportService[]
  packageTransportServices  PackageTransportService[]
  resellerId                String?
  reseller                  Reseller?                     @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([providerId])
  @@index([originDestinationId])
  @@index([destinationDestinationId])
  @@index([cityId])
  @@index([active, isTemplate])
  @@index([resellerId])
}

// ─── Relational Tourism Catalog Spine ─────────────────────────────
model DestinationHotel {
  id            String   @id @default(cuid())
  destinationId String
  hotelId       String
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  hotel       Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([destinationId, hotelId])
  @@index([destinationId, active, sortOrder])
  @@index([hotelId])
}

model DestinationPackage {
  id            String   @id @default(cuid())
  destinationId String
  packageId     String
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination   @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  package     TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([destinationId, packageId])
  @@index([destinationId, active, sortOrder])
  @@index([packageId])
}

model DestinationExcursion {
  id            String   @id @default(cuid())
  destinationId String
  excursionId   String
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  excursion   Excursion   @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@unique([destinationId, excursionId])
  @@index([destinationId, active, sortOrder])
  @@index([excursionId])
}

model DestinationTransportService {
  id                 String   @id @default(cuid())
  destinationId      String
  transportServiceId String
  featured           Boolean  @default(false)
  sortOrder          Int      @default(0)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  destination      Destination      @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  transportService TransportService @relation(fields: [transportServiceId], references: [id], onDelete: Cascade)

  @@unique([destinationId, transportServiceId])
  @@index([destinationId, active, sortOrder])
  @@index([transportServiceId])
}

model PackageHotel {
  id        String   @id @default(cuid())
  packageId String
  hotelId   String
  role      String   @default("lodging")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  package TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  hotel   Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([packageId, hotelId, role])
  @@index([packageId, active, sortOrder])
  @@index([hotelId])
}

model PackageExcursion {
  id          String   @id @default(cuid())
  packageId   String
  excursionId String
  included    Boolean  @default(true)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  excursion Excursion     @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@unique([packageId, excursionId])
  @@index([packageId, active, sortOrder])
  @@index([excursionId])
}

model PackageTransportService {
  id                 String   @id @default(cuid())
  packageId          String
  transportServiceId String
  role               String   @default("transfer")
  sortOrder          Int      @default(0)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  package          TravelPackage    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  transportService TransportService @relation(fields: [transportServiceId], references: [id], onDelete: Cascade)

  @@unique([packageId, transportServiceId, role])
  @@index([packageId, active, sortOrder])
  @@index([transportServiceId])
}

model PackageRoomType {
  id         String   @id @default(cuid())
  packageId  String
  roomTypeId String
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  package  TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  roomType RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([packageId, roomTypeId])
  @@index([packageId, active, sortOrder])
  @@index([roomTypeId])
}

model PackageDepartureDate {
  id             String    @id @default(cuid())
  packageId      String
  dateFrom       DateTime
  dateTo         DateTime?
  availableSeats Int       @default(0)
  price          Int?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  package TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, dateFrom])
  @@index([packageId, active, dateFrom])
}

model PackageItineraryDay {
  id          String   @id @default(cuid())
  packageId   String
  day         Int
  title       String   @default("")
  description String   @default("")
  activities  String   @default("[]")
  meals       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  package TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, day])
  @@index([packageId, day])
}

model PackageIncludedService {
  id          String   @id @default(cuid())
  packageId   String
  serviceType String   @default("general")
  name        String
  description String   @default("")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  package TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, serviceType, name])
  @@index([packageId, active, sortOrder])
}

// ─── Cruises ──────────────────────────────────────────────────────
model Cruise {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  description          String   @default("")
  shipName             String   @default("")
  operator             String   @default("")
  durationDays         Int      @default(3)
  images               String   @default("[]") // JSON array of image URLs
  includes             String   @default("[]") // JSON array
  itinerary            String   @default("[]") // JSON array of stops
  rating               Float    @default(0)
  reviewCount          Int      @default(0)
  priceFrom            Int      @default(0)
  tags                 String   @default("[]") // JSON array
  featured             Boolean  @default(false)
  active               Boolean  @default(true)
  isTemplate           Boolean  @default(true)
  publishStatus        String   @default("approved")
  primaryDestinationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  primaryDestination Destination?        @relation("CruisePrimaryDestination", fields: [primaryDestinationId], references: [id], onDelete: SetNull)
  destinations       DestinationCruise[]
  cabins             CruiseCabin[]
  resellerId         String?
  reseller           Reseller?           @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([primaryDestinationId])
  @@index([active, isTemplate])
  @@index([featured, active])
  @@index([resellerId])
}

model CruiseCabin {
  id            String   @id @default(cuid())
  cruiseId      String
  name          String
  capacity      Int      @default(2)
  beds          String   @default("2 camas individuales")
  basePrice     Int      @default(0)
  originalPrice Int      @default(0)
  includes      String   @default("[]") // JSON array
  cabinImage    String   @default("")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cruise Cruise @relation(fields: [cruiseId], references: [id], onDelete: Cascade)

  @@index([cruiseId, active])
}

model DestinationCruise {
  id            String   @id @default(cuid())
  destinationId String
  cruiseId      String
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  cruise      Cruise      @relation(fields: [cruiseId], references: [id], onDelete: Cascade)

  @@unique([destinationId, cruiseId])
  @@index([destinationId, active, sortOrder])
  @@index([cruiseId])
}

// ─── Help Articles / Documentation CMS ───────────────────────────
model HelpArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String   @default("general")
  content     String   @default("") // Markdown content
  imageLabels String   @default("[]") // JSON array of [Captura: ...] labels
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, published])
  @@index([sortOrder])
}
