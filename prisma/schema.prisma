generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin User ──────────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Destinations ────────────────────────────────────────────────
model Destination {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  region      String
  description String
  image       String
  highlights  String   // JSON array stored as string
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  priceFrom   Int      @default(0)
  active      Boolean  @default(true)
  isTemplate  Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Hotels ──────────────────────────────────────────────────────
model Hotel {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  cityId      String
  cityName    String
  stars       Int          @default(3)
  address     String       @default("")
  description String       @default("")
  images      String       @default("[]") // JSON array
  amenities   String       @default("[]") // JSON array of amenity IDs
  rooms       String       @default("[]") // JSON array of HotelRoom objects
  rating      Float        @default(0)
  reviewCount Int          @default(0)
  priceFrom   Int          @default(0)
  tags        String       @default("[]") // JSON array
  featured    Boolean      @default(false)
  active      Boolean      @default(true)
  isTemplate  Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  roomTypes   RoomType[]
  allotments  Allotment[]
}

// ─── Room Types ──────────────────────────────────────────────────
model RoomType {
  id            String      @id @default(cuid())
  hotelId       String
  name          String
  maxGuests     Int         @default(2)
  beds          String      @default("1 cama doble")
  basePrice     Int         @default(0)
  originalPrice Int         @default(0)
  includes      String      @default("[]") // JSON array
  roomImage     String      @default("")
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  hotel         Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  allotments    Allotment[]
}

// ─── Allotments ──────────────────────────────────────────────────
model Allotment {
  id           String   @id @default(cuid())
  hotelId      String
  roomTypeId   String
  dateFrom     DateTime
  dateTo       DateTime
  totalRooms   Int      @default(0)
  bookedRooms  Int      @default(0)
  releaseDays  Int      @default(3)
  netPrice     Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType     RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
}

// ─── Marketing Modal ─────────────────────────────────────────────
model MarketingModal {
  id          String   @id @default(cuid())
  active      Boolean  @default(true)
  title       String   @default("")
  subtitle    String   @default("")
  description String   @default("")
  imageUrl    String   @default("")
  ctaText     String   @default("Ver Oferta")
  ctaLink     String   @default("")
  ctaType     String   @default("link") // "link" | "navigate" — link opens URL, navigate uses SPA view
  timerEnabled Boolean @default(false)
  timerLabel  String   @default("Oferta termina en")
  timerEnd    DateTime?
  position    String   @default("center") // "center" | "bottom-right" | "bottom-left"
  delayMs     Int      @default(3000) // delay before showing modal (ms)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Travel Packages ─────────────────────────────────────────────
model TravelPackage {
  id              String   @id @default(cuid())
  slug            String   @unique
  destinationId   String
  destinationName String
  title           String
  description     String
  duration        String
  price           Int
  originalPrice   Int?
  includes        String   @default("[]") // JSON array
  image           String   @default("")
  difficulty      String   @default("Fácil")
  groupSize       String   @default("")
  departureDates  String   @default("[]") // JSON array
  rating          Float    @default(0)
  soldOut         Boolean  @default(false)
  category        String   @default("Cultural")
  commission      Int      @default(10)
  active          Boolean  @default(true)
  isTemplate      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Excursions ───────────────────────────────────────────────────
model Excursion {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  destinationId   String
  destinationName String
  cityName        String
  description     String
  shortDesc       String   @default("")
  images          String   @default("[]") // JSON array
  duration        String   @default("")
  difficulty      String   @default("Fácil")
  groupSize       String   @default("")
  basePrice       Int      @default(0)
  childPrice      Int      @default(0)
  includes        String   @default("[]") // JSON array
  excludes        String   @default("[]") // JSON array
  requirements    String   @default("[]") // JSON array
  category        String   @default("")
  rating          Float    @default(0)
  featured        Boolean  @default(false)
  active          Boolean  @default(true)
  isTemplate      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Subagents ────────────────────────────────────────────────────
model Subagent {
  id          String    @id @default(cuid())
  code        String    @unique
  email       String    @unique
  password    String
  agencyName  String    @default("")
  contactName String    @default("")
  country     String    @default("")
  phone       String    @default("")
  commission  Int       @default(0)
  sellerLevel String    @default("standard")
  whiteLabelEnabled Boolean @default(false)
  active      Boolean   @default(false)
  approvalStatus String @default("pending")
  registrationDate DateTime @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  bookings    Booking[]
}

// ─── Bookings ─────────────────────────────────────────────────────
model Booking {
  id           String         @id @default(cuid())
  code         String         @unique
  guestName    String         @default("")
  guestEmail   String         @default("")
  guestPhone   String         @default("")
  guestCountry String         @default("")
  adults       Int            @default(1)
  children     Int            @default(0)
  childrenAges String         @default("[]") // JSON array
  notes        String         @default("")
  status       String         @default("pending")
  totalPrice   Int            @default(0)
  netPrice     Int            @default(0)
  commissionAmt Int           @default(0)
  checkIn      DateTime?
  checkOut     DateTime?
  bookedBy     String         @default("b2c") // "b2c" | "b2b"
  subagentId   String?
  resellerId   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  items        BookingItem[]
  subagent     Subagent?      @relation(fields: [subagentId], references: [id], onDelete: SetNull)
  reseller     Reseller?      @relation(fields: [resellerId], references: [id], onDelete: SetNull)
}

// ─── Booking Items ────────────────────────────────────────────────
model BookingItem {
  id        String   @id @default(cuid())
  bookingId String
  itemType  String   @default("")  // "hotel", "excursion", "transport", etc.
  serviceId String   @default("")
  serviceName String @default("")
  roomTypeId String  @default("")
  roomName  String   @default("")
  dateFrom  String   @default("")
  dateTo    String   @default("")
  quantity  Int      @default(1)
  unitPrice Int      @default(0)
  totalPrice Int     @default(0)
  addons    String   @default("[]") // JSON array
  status    String   @default("confirmed")
  createdAt DateTime @default(now())
  
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ─── Transport Providers ───────────────────────────────────────────
model TransportProvider {
  id          String             @id @default(cuid())
  name        String
  legalName   String             @default("")
  nit         String             @default("")
  phone       String             @default("")
  email       String             @default("")
  vehicleType String             @default("")
  capacity    Int                @default(0)
  active      Boolean            @default(true)
  isTemplate  Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  services    TransportService[]
}

// ─── Transport Services ────────────────────────────────────────────
model TransportService {
  id         String            @id @default(cuid())
  providerId String
  name       String
  routeType  String            @default("")
  origin     String            @default("")
  destination String           @default("")
  cityId     String            @default("")
  cityName   String            @default("")
  durationMins Int             @default(0)
  basePrice  Int               @default(0)
  pricePerExtra Int            @default(0)
  includes   String            @default("[]") // JSON array
  notes      String            @default("")
  active     Boolean           @default(true)
  isTemplate Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  
  provider   TransportProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

// ─── Resellers ──────────────────────────────────────────────────────
model Reseller {
  id              String             @id @default(cuid())
  code            String             @unique            // RES-0001
  email           String             @unique
  password        String
  companyName     String             @default("")
  contactName     String             @default("")
  country         String             @default("")
  phone           String             @default("")
  website         String             @default("")
  taxId           String             @default("")       // NIT/RUT/identificación fiscal
  address         String             @default("")
  logoUrl         String             @default("")
  sellerLevel     String             @default("standard") // starter | standard | free_light
  commission      Int                @default(0)         // % base de comisión
  whiteLabelEnabled Boolean          @default(false)
  active          Boolean            @default(false)
  approvalStatus  String             @default("pending")  // pending | under_review | approved | rejected
  rejectionReason String             @default("")
  registrationDate DateTime          @default(now())
  approvedAt      DateTime?
  approvedBy      String?            // Admin ID que aprobó
  lastLoginAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  catalogs        ResellerCatalog[]
  sales           ResellerSale[]
  clients         ResellerClient[]
  documents       ResellerDocument[]
  bookings        Booking[]
}

// ─── Reseller Catalog (productos personalizados del revendedor) ────
model ResellerCatalog {
  id               String   @id @default(cuid())
  resellerId       String
  sourceType       String    // "hotel" | "excursion" | "package" | "transport" | "room" | "destination"
  sourceId         String    // ID del modelo origen
  customPrice      Int?      // Precio personalizado (null = usa precio base)
  customName       String   @default("")  // "" = usa nombre original
  customDescription String  @default("")  // "" = usa descripción original
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reseller         Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@unique([resellerId, sourceType, sourceId])
  @@index([resellerId, sourceType])
  @@index([resellerId, active])
}

// ─── Reseller Sales (ventas del revendedor) ────────────────────────
model ResellerSale {
  id            String   @id @default(cuid())
  resellerId    String
  bookingId     String?  // Enlace a Booking existente
  clientName    String   @default("")
  clientEmail   String   @default("")
  totalAmount   Int      @default(0)
  commissionAmt Int      @default(0)  // Monto de comisión ganado
  netAmount     Int      @default(0)  // Lo que paga al operador
  status        String   @default("pending")  // pending | confirmed | completed | cancelled
  saleDate      DateTime @default(now())
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reseller      Reseller @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  @@index([resellerId, status])
  @@index([resellerId, saleDate])
}

// ─── Reseller Clients (clientes del revendedor) ────────────────────
model ResellerClient {
  id            String   @id @default(cuid())
  resellerId    String
  name          String
  email         String
  phone         String   @default("")
  country       String   @default("")
  passport      String   @default("")
  notes         String   @default("")
  totalPurchases Int     @default(0)  // Count
  totalSpent    Int      @default(0)  // Sum in cents
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reseller      Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId, email])
  @@index([resellerId, name])
}

// ─── Reseller Documents (documentos de verificación) ───────────────
model ResellerDocument {
  id            String   @id @default(cuid())
  resellerId    String
  docType       String    // "business_license" | "tax_id" | "id_card" | "other"
  fileName      String
  fileUrl       String
  status        String   @default("pending")  // pending | approved | rejected
  reviewerNotes String   @default("")
  uploadedAt    DateTime @default(now())
  reviewedAt    DateTime?

  reseller      Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId, status])
}
